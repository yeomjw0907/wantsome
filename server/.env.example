# IAP — App Store Connect / Google Play 검증용 (server 배포 시 설정)
# 실제 값은 server/.env 에만 두고 커밋하지 마세요.

# App Store Connect → 앱 정보 → 공유 암호 (App-Specific Shared Secret)
APPLE_IAP_SHARED_SECRET=

# Google Play: 서비스 계정 JSON 전체를 한 줄로 (또는 파일 경로를 쓰는 방식으로 코드 지원 시)
# 예: JSON 내부 따옴표 이스케이프 또는 minify 한 줄
GOOGLE_SERVICE_ACCOUNT_JSON=
