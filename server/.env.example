# IAP — App Store / Google Play 영수증 서버 검증용
# 실제 값은 server/.env 에만 두고 커밋하지 마세요.

# ────────────────────────────────────────────────────────────
# Apple App Store Server API (JWT 기반, 권장)
# - shared secret 방식은 deprecated. App Store Server Library 사용
# - App Store Connect → Users and Access → Integrations → API Keys
# ────────────────────────────────────────────────────────────
APPLE_ISSUER_ID=
APPLE_KEY_ID=
# .p8 파일 내용 전체 (PEM 형식, 줄바꿈 \n 으로)
APPLE_PRIVATE_KEY=
APPLE_BUNDLE_ID=kr.wantsome.app
# Production | Sandbox (개발 시 Sandbox)
APPLE_ENVIRONMENT=Production

# (Deprecated, 사용 안 함 — 위 JWT 방식으로 통합됨)
# APPLE_IAP_SHARED_SECRET=

# Apple App Store Server Notification V2 webhook 서명 검증용
# - Apple PKI 사이트(https://www.apple.com/certificateauthority/)에서
#   Apple Root CA (G3 등) 인증서 다운로드 후 PEM 형식 전체 concat
# - 미설정 시 webhook은 받되 status 마킹 안 함 (fail-closed)
APPLE_ROOT_CAS_PEM=

# ────────────────────────────────────────────────────────────
# Google Play Developer API (Service Account)
# - Google Cloud Console → IAM → Service Accounts → JSON Key
# - Play Console → API access → 위 service account 연결
#   + "View financial data" 권한 부여
# ────────────────────────────────────────────────────────────
GOOGLE_PACKAGE_NAME=kr.wantsome.app
# JSON 내용 전체를 한 줄로 minify 후 단일 따옴표로 감싸서 (또는 escape)
GOOGLE_SERVICE_ACCOUNT_JSON=

# Google Pub/Sub RTDN OIDC token 검증용 (push subscription audience)
# - Pub/Sub push subscription 생성 시 'Audience' 필드에 입력한 값
#   보통 endpoint URL: https://api.wantsome.kr/api/payments/google-rtdn
GOOGLE_RTDN_AUDIENCE=
# (옵션) Pub/Sub 서비스 계정 이메일 — 미설정 시 OIDC 검증만 하고 sender 일치 검사 skip
GOOGLE_RTDN_SENDER_EMAIL=

# ────────────────────────────────────────────────────────────
# 인증·보안
# ────────────────────────────────────────────────────────────
# Vercel Cron 호출 인증 (16자 이상 long string)
# 생성: openssl rand -hex 32
CRON_SECRET=

# PortOne 본인인증 v2 API Secret
# - PortOne 콘솔 → 결제 연동 → API 키
# - 미설정 시 verify-identity가 fail-closed (500 반환)
PORTONE_API_SECRET=

# 크리에이터 계좌번호 AES-256-GCM 암호화 키 (32 bytes = 64 hex chars)
# 생성: openssl rand -hex 32
# ⚠️ 미설정 또는 잘못된 형식 시 creators/register 가 500 반환 (fail-closed)
ACCOUNT_ENCRYPT_KEY=

# Slack 정산·운영 알림
SLACK_WEBHOOK_URL=
